{
  "name": "emoji-osory",
  "version": "2.0.0",
  "description": "Browser-first emoji fingerprinting toolkit with a static demo and reproducible data pipeline.",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "exports": {
    ".": "./src/index.js",
    "./browser": "./src/browser/index.js",
    "./runtime-dataset": "./data/browser-runtime-dataset.json"
  },
  "files": [
    "src",
    "data/browser-runtime-dataset.json",
    "data/emoji-fingerprint-db.json",
    "data/emoji-fingerprint-db.min.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite",
    "preview": "vite preview",
    "parse": "node scripts/parse-unicode-emoji.js",
    "noto": "node scripts/generate-noto-data.js",
    "sanitize": "node sanitize-vendor-data.js",
    "build:data": "npm run parse && npm run noto && npm run sanitize && node scripts/build-master-database.js",
    "build": "npm run build:data && vite build",
    "lint": "eslint .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:no-emoji": "node tools/check-no-emoji.mjs",
    "verify": "npm run check:no-emoji && npm run lint && npm run format:check && npm run test && npm run build"
  },
  "dependencies": {},
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "eslint": "^9.23.0",
    "globals": "^16.0.0",
    "jsdom": "^26.0.0",
    "prettier": "^3.5.3",
    "vite": "^6.2.0",
    "vitest": "^3.0.8"
  }
}
